{
  "name": "future-org-design",
  "private": true,
  "type": "module",
  "description": "ODaaS research and lat.md knowledge graph",
  "scripts": {
    "prepare": "node scripts/git-set-hooks.mjs",
    "git:hooks": "node scripts/git-set-hooks.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lat:check": "lat --dir docs check",
    "graph:view": "tsx src/knowledge-graph/write-graph-view.cli.ts",
    "graph:check": "tsx src/knowledge-graph/check-graph-view.cli.ts",
    "integration:check": "npm run typecheck && npm run lat:check && npm test && npm run bdd",
    "verify": "npm run integration:check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && npm run graph:check",
    "test:watch": "vitest",
    "bdd": "NODE_OPTIONS='--import tsx' cucumber-js --config cucumber.mjs",
    "bdd:org-model": "npm run bdd -- --tags '@org-model-intelligence'"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lat.md": "^0.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
